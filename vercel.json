{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/style.css",
      "dest": "/public/style.css"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/routines.js",
      "dest": "/public/routines.js"
    },
    {
      "src": "/about.html",
      "dest": "/public/about.html"
    },
    {
      "src": "/routines.html",
      "dest": "/public/routines.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}